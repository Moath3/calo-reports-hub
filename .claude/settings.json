{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c).on('end',()=>{try{const f=(JSON.parse(d).tool_input||{}).file_path||'';if(/(\\.env|\\.db$|credentials|secrets\\.|\\.key$)/.test(f)){console.error('BLOCK: sensitive file '+f);process.exit(2)}}catch(e){}})\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c).on('end',()=>{try{const f=(JSON.parse(d).tool_input||{}).file_path||'';if(/\\.(js|jsx|ts|tsx|json|css|md)$/.test(f)){require('child_process').execSync('npx prettier --write '+JSON.stringify(f),{stdio:'ignore'})}}catch(e){}})\""
          }
        ]
      }
    ]
  }
}
