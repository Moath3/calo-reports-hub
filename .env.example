# Server
PORT=3001
NODE_ENV=development

# JWT Secret — REQUIRED in production
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-64-chars

# Company Registration Code (employees need this to register)
COMPANY_REG_CODE=your-company-code

# Bootstrap admin (optional). At boot, seeds this admin if it doesn't exist.
# Leave BOTH unset to skip seeding — an existing admin in the DB is untouched.
SEED_ADMIN_EMAIL=admin@calo.app
SEED_ADMIN_PASSWORD=set-a-strong-password
# One-time password rotation: set to true with a NEW SEED_ADMIN_PASSWORD to
# overwrite the existing admin's password on next boot, then UNSET it.
# SEED_ADMIN_FORCE_PASSWORD=true

# AI Provider API Keys (at least one required for report generation)
GEMINI_API_KEY=your-gemini-api-key
CLAUDE_API_KEY=your-claude-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key

# Default AI Provider (gemini | claude | perplexity)
DEFAULT_AI_PROVIDER=claude

# Netlify (optional — for report publishing)
NETLIFY_ACCESS_TOKEN=your-netlify-token

# File Upload Limits
MAX_FILE_SIZE_MB=25

# Email Notifications (optional — Resend API for admin notifications)
RESEND_API_KEY=your-resend-api-key
ADMIN_EMAIL=admin@your-domain.com

# Frontend URL (optional — set in production for strict CORS)
# If not set, same-origin policy applies (recommended for Render single-service deploy)
# FRONTEND_URL=https://your-app.onrender.com
